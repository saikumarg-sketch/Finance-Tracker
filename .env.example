# These are auto-injected by Vercel when you install the Upstash Redis integration.
# Depending on the install flow you use, env vars may be named either way.
# The app supports both — you only need one pair set.

# Upstash Marketplace integration:
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Or legacy Vercel KV compatibility:
# KV_REST_API_URL=
# KV_REST_API_TOKEN=

# For local development, run: npx vercel env pull .env.local
